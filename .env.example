# eSumbong Environment Variables
# Copy this file to .env.local and fill in your keys

# UniSMS API Key (for real SMS sending)
# Get yours from https://unismsapi.com
# Leave empty to use simulation mode (toast-based, no real SMS)
NEXT_PUBLIC_UNISMS_API_KEY=

# Optional: Gemini API Key (for AI categorization)
# The app works without this — uses keyword-based categorization as fallback
NEXT_PUBLIC_GEMINI_API_KEY=
